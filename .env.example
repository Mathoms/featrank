# .env — copy this file to .env and fill in your values
# NEVER commit .env to git

# LLM Provider (pick one: groq | ollama)
GROQ_API_KEY=your_key_here
OLLAMA_BASE_URL=http://localhost:11434

# LLM config
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile
OLLAMA_MODEL=gemma3:4b

# Embedding model (HuggingFace model id)
EMBEDDING_MODEL=all-mpnet-base-v2

# GitHub (optional — for implementation signal)
GITHUB_TOKEN=your_token_here
GITHUB_REPO=owner/repo

# Intercom (optional)
INTERCOM_TOKEN=your_token_here

# Zendesk (optional)
ZENDESK_SUBDOMAIN=yourcompany
ZENDESK_EMAIL=you@company.com
ZENDESK_API_TOKEN=your_token_here

# Scoring weights (must sum to 1.0)
WEIGHT_FREQUENCY=0.20
WEIGHT_SEGMENT_VALUE=0.40
WEIGHT_GITHUB_SIGNAL=0.20
WEIGHT_ROADMAP_FIT=0.20

# API
API_HOST=0.0.0.0
API_PORT=8000

# Cache directory for embeddings
CACHE_DIR=.cache/embeddings
